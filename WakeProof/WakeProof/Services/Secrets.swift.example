//
//  Secrets.swift.example
//  WakeProof
//
//  Copy this file to `Secrets.swift` in the same folder. `Secrets.swift` is git-ignored.
//  DO NOT commit the real API key anywhere. If you accidentally commit one, rotate it immediately.
//

import Foundation

enum Secrets {
    /// Claude API key from console.anthropic.com.
    /// For the hackathon, use the dedicated $500 credit key — not your production key.
    static let claudeAPIKey: String = "sk-ant-REPLACE_ME"

    /// The endpoint the iOS app POSTs verification requests to. Leave empty to hit
    /// Anthropic directly (will 403 on device due to Cloudflare Bot Management — see
    /// `workers/wakeproof-proxy/README.md`). Set to your deployed Cloudflare Worker URL
    /// including the `/v1/messages` path after running `wrangler deploy`, e.g.
    ///   "https://wakeproof-proxy.<your-subdomain>.workers.dev/v1/messages"
    static let claudeEndpoint: String = ""

    /// Model identifiers. Kept here so we can swap models in one place.
    static let visionModel: String = "claude-opus-4-7"
    static let textModel: String = "claude-sonnet-4-6"
}
