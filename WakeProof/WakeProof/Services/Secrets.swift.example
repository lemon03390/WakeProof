//
//  Secrets.swift.example
//  WakeProof
//
//  Copy this file to `Secrets.swift` in the same folder. `Secrets.swift` is git-ignored.
//  DO NOT commit the real API key anywhere. If you accidentally commit one, rotate it immediately.
//

import Foundation

enum Secrets {
    /// Per-install shared token used to authenticate this iOS client to our Vercel
    /// proxy (`workers/wakeproof-proxy-vercel/`). The Anthropic API key itself lives
    /// in a Vercel env var (`ANTHROPIC_API_KEY`) — it is NOT shipped inside this
    /// binary anymore. The proxy validates this token against its
    /// `WAKEPROOF_CLIENT_TOKEN` env var and rejects unauthorized callers with 401.
    ///
    /// Generate with `openssl rand -hex 32`. The SAME value must be set as the
    /// `WAKEPROOF_CLIENT_TOKEN` env var on Vercel (`vercel env add WAKEPROOF_CLIENT_TOKEN production`).
    /// Rotation: regenerate, update both sides, redeploy + reinstall.
    ///
    /// Security posture: the token sits inside the .ipa alongside the source. A
    /// determined attacker can extract it with `strings`. It's a "bounds abuse"
    /// measure — much weaker than a rotating per-install token but much stronger
    /// than shipping the Anthropic credential directly. Trivially rotatable if
    /// leakage is observed.
    static let wakeproofToken: String = "REPLACE_WITH_OPENSSL_RAND_HEX_32"

    /// The endpoint the iOS app POSTs verification requests to. Leave empty to hit
    /// Anthropic directly (will 403 on device due to Cloudflare Bot Management).
    ///
    /// **Recommended:** deploy `workers/wakeproof-proxy-vercel/` and paste the
    /// production URL here, e.g.
    ///   "https://wakeproof-proxy-<hash>.vercel.app/v1/messages"
    ///
    /// Cloudflare Worker fallback at `workers/wakeproof-proxy/` is ARCHIVED
    /// (see its README) — Vercel Serverless is the production path.
    static let claudeEndpoint: String = ""

    /// Model identifiers. Kept here so we can swap models in one place.
    static let visionModel: String = "claude-opus-4-7"
    static let textModel: String = "claude-sonnet-4-6"
}
